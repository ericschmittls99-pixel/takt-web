# Dependencies
node_modules/

# Build output
dist/
.vite/
*.tsbuildinfo

# Cloudflare
.wrangler/
.dev.vars

# Env
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Claude Code (user-local)
.claude/settings.local.json

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Garmin (lokal): venv, Token-Cache und Roh-Samples nie committen
garmin/venv/
garmin/.garth/
garmin/samples/
# Temp-SQL-Dateien des Sync (NamedTemporaryFile; via try/finally gelöscht, Rest bei Hard-Kill)
garmin/tmp*.sql
# Sync-Logs (launchd): Inhalt ignorieren, Ordner via .gitkeep behalten
garmin/logs/*
!garmin/logs/.gitkeep
__pycache__/
